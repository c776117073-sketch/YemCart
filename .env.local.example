NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# Setup Instructions:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project named "yemcart"
# 3. Create a web app in the project
# 4. Copy the Firebase config values to the variables above
# 5. Enable the following in Firebase Console:
#    - Authentication: Email/Password and Google
#    - Firestore Database: Start in production mode
#    - Storage: Create a storage bucket
#
# 6. Add the Firestore Security Rules (see FIRESTORE_RULES.txt)
#
# 7. Run: npm install
# 8. Run: npm run dev

WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_BUSINESS_API_KEY=your_api_key
